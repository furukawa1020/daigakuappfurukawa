<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DaigakuOS - Web Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=Outfit:wght@700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --primary: #38bdf8;
      --secondary: #818cf8;
      --text: #f8fafc;
      --text-muted: #94a3b8;
    }
    body {
      margin: 0; padding: 0;
      background-color: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
    }
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem;
    }
    .header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 3rem;
    }
    .logo {
      font-family: 'Outfit', sans-serif;
      font-size: 2.5rem;
      background: linear-gradient(135deg, #38bdf8, #c084fc);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin: 0;
    }
    .stats-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem; margin-bottom: 3rem;
    }
    .stat-card {
      background: var(--surface);
      border-radius: 1rem;
      padding: 1.5rem;
      box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.3);
    }
    .stat-title {
      font-size: 0.875rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;
    }
    .stat-value {
      font-size: 2.5rem; font-weight: 800; margin-top: 0.5rem; color: var(--primary);
    }
    
    .section-title {
      font-family: 'Outfit', sans-serif; font-size: 2rem; margin-bottom: 1.5rem; color: var(--text);
    }
    .moko-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;
    }
    .moko-card {
      background: linear-gradient(to bottom right, var(--surface), #151e2e);
      border: 1px solid #334155;
      border-radius: 1.5rem;
      padding: 1.5rem; text-align: center;
      transition: all 0.2s;
    }
    .moko-card:hover {
      border-color: var(--primary);
      transform: scale(1.02);
    }
    .moko-name { font-weight: 600; font-size: 1.25rem; margin-bottom: 0.5rem; }
    .moko-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; }
  </style>
</head>
<body>
  <div class="container">
    <header class="header">
      <h1 class="logo">DaigakuOS Web</h1>
      <div style="color: var(--text-muted);">Ruby on Rails <%= Rails.version %></div>
    </header>

  <!-- Moko World Status Banner -->
  <% world = MokoWorldService.current_status %>
  <div id="world-banner" style="background: linear-gradient(90deg, #3b82f6, #8b5cf6); padding: 1rem; text-align: center; font-weight: bold; margin-bottom: 2rem; border-radius: 0.75rem; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
    🌍 <span id="world-weather"><%= world[:weather]&.upcase %></span>: 
    <span id="world-event-name" style="color: #fbbf24; margin-left: 0.5rem;"><%= world[:event_name] %></span>
  </div>

  <!-- Phase 36: Global Raid Boss Section -->
  <% if @active_raid %>
    <div id="raid-boss-container" class="stat-card" style="margin-bottom: 2rem; border: 2px solid #ef4444; background: rgba(239, 68, 68, 0.05); position: relative; overflow: hidden;">
      <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 1rem;">
        <div>
          <div style="font-size: 0.8rem; color: #fca5a5; font-weight: bold; text-transform: uppercase;">Global Raid Event</div>
          <h2 style="font-family: 'Outfit', sans-serif; font-size: 2.5rem; margin: 0; color: #fecaca;"><%= @active_raid.title %></h2>
        </div>
        <div style="text-align: right;">
          <div id="raid-hp-text" style="font-size: 1.5rem; font-weight: 800; color: #ef4444;">
            <%= number_with_delimiter(@active_raid.current_hp) %> / <%= number_with_delimiter(@active_raid.max_hp) %> HP
          </div>
          <div style="font-size: 0.8rem; color: var(--text-muted);">Ends at: <%= @active_raid.ends_at.strftime("%H:%M") %></div>
        </div>
      </div>
      
      <div style="background: rgba(0,0,0,0.4); height: 24px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 1rem;">
        <div id="raid-hp-bar" style="width: <%= @active_raid.health_percentage %>%; height: 100%; background: linear-gradient(90deg, #ef4444, #b91c1c); transition: width 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);"></div>
      </div>

      <div id="raid-logs" style="font-size: 0.8rem; height: 60px; overflow-y: hidden; color: #fca5a5; border-top: 1px solid rgba(239,68,68,0.2); padding-top: 0.5rem;">
        <div class="raid-log-entry">全員で集中してボスを倒そう！実績時間がダメージになるもこ！</div>
      </div>
    </div>
  <% end %>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-title">Total Users</div>
        <div class="stat-value"><%= @total_users %></div>
      </div>
      <div class="stat-card">
        <div class="stat-title">Total Sessions</div>
        <div class="stat-value"><%= @total_sessions %></div>
      </div>
      <div class="stat-card">
        <div class="stat-title">Global Focus Hours</div>
        <div class="stat-value"><%= (@total_focus_minutes / 60.0).round(1) %>h</div>
      </div>
    </div>

    <h2 class="section-title">Active Mokos in the World</h2>
    <div class="moko-grid">
      <% @users.each do |data| %>
        <% u = data[:user] %>
        <% evo = data[:evolution] %>
        <div class="moko-card" style="position: relative; overflow: hidden;">
          <% if evo[:unlocked] %>
            <div style="position: absolute; top: 10px; right: 10px; font-size: 0.7rem; background: var(--primary); padding: 2px 8px; border-radius: 1rem; color: var(--bg); font-weight: bold;">
              EVOLVED
            </div>
          <% end %>
          <div class="moko-name"><%= u.username %> の相棒</div>
          <div style="font-size: 1.2rem; margin: 1rem 0;"><%= evo[:name] %> 🐾</div>
          <div style="font-size: 0.8rem; color: var(--secondary); margin-bottom: 0.5rem;">
            特性: <%= evo[:trait] %> | 気分: <span style="font-weight: bold; color: var(--primary);"><%= u.moko_mood&.upcase %></span>
          </div>
          <div style="font-size: 0.85rem; font-style: italic; color: #e2e8f0; background: rgba(255,255,255,0.05); padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem;">
            「<%= u.whisper ? u.whisper["message"] : "もこもこ！一緒に頑張ろう！" %>」
          </div>
          <% recent_events = u.social_events.order(created_at: :desc).limit(2) %>
          <% if recent_events.any? %>
            <div style="text-align: left; font-size: 0.75rem; background: rgba(56, 189, 248, 0.1); padding: 0.5rem; border-radius: 0.4rem; margin-bottom: 0.5rem;">
              <div style="color: var(--primary); font-weight: bold; margin-bottom: 2px;">Recent Social:</div>
              <% recent_events.each do |e| %>
                <div style="margin-bottom: 2px; border-bottom: 1px solid rgba(255,255,255,0.05);"><%= e.metadata["message"] || e.event_type %></div>
              <% end %>
            </div>
          <% end %>

          <!-- Phase 34: Active Expedition (Boss Battle) -->
          <% active_exp = u.moko_expeditions.active.first %>
          <% if active_exp %>
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); padding: 0.5rem; border-radius: 0.4rem; margin-bottom: 0.5rem;">
              <div style="font-size: 0.75rem; color: #fca5a5; font-weight: bold; margin-bottom: 4px;">⚔️ <%= active_exp.name %></div>
              <% hp_percent = [(active_exp.monster_hp.to_f / active_exp.required_focus_minutes) * 100, 100].min %>
              <div style="background: rgba(0,0,0,0.3); height: 8px; border-radius: 4px; overflow: hidden; margin-bottom: 2px;">
                <div style="width: <%= hp_percent %>%; height: 100%; background: #ef4444;"></div>
              </div>
              <div style="font-size: 0.65rem; color: #fca5a5; text-align: right;">HP: <%= active_exp.monster_hp %></div>
            </div>
          <% end %>

          <!-- Phase 33: Materials & Synergy -->
          <div style="display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 0.5rem;">
            <% (u.materials || {}).each do |mat, qty| %>
              <div title="<%= mat %>" style="background: rgba(255,255,255,0.1); padding: 2px 6px; border-radius: 10px; font-size: 0.7rem;">
                <%= mat == "moko_stone" ? "💎" : "✨" %> <%= qty %>
              </div>
            <% end %>
          </div>

          <% buffs = FocusSynergyService.calculate_buffs(u) %>
          <% if buffs.any? %>
            <div style="font-size: 0.7rem; color: #10b981; font-weight: bold;">
              ⚡ BUFF: <%= buffs.map{|b| b[:name]}.join(", ") %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <h2 class="section-title">Community Intelligence & Performance</h2>
    <div class="stats-grid">
      <div class="stat-card" style="border-left: 4px solid var(--secondary);">
        <div class="stat-title">Recent Activity Latency</div>
        <div style="margin-top: 1rem; font-size: 0.8rem;">
          <% if @recent_perf.any? %>
            <% @recent_perf.each do |p| %>
              <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                <span style="color: var(--text-muted);"><%= p[:path] %></span>
                <span style="color: <%= p[:duration] > 200 ? '#f87171' : '#4ade80' %>;"><%= p[:duration] %>ms</span>
              </div>
            <% end %>
          <% else %>
            <div style="color: var(--text-muted);">No metrics yet. Try syncing from the app!</div>
          <% end %>
        </div>
      </div>
      
      <% report = Rails.cache.read("global_report_#{Date.today}") %>
      <div class="stat-card" style="border-left: 4px solid #c084fc;">
        <div class="stat-title">Daily Community Pulse</div>
        <% if report %>
          <div style="margin-top: 1rem;">
            <div style="font-size: 1.1rem; font-weight: 600;"><%= report[:popular_moko] || "???" %></div>
            <div style="font-size: 0.8rem; color: var(--text-muted);">Today's Most Popular Moko</div>
            <div style="margin-top: 0.5rem; font-size: 0.8rem;">
              Updated: <%= report[:generated_at].strftime("%H:%M") %>
            </div>
          </div>
        <% else %>
          <div style="margin-top: 1rem; color: var(--text-muted);">Generating today's report...</div>
        <% end %>
      </div>
    </div>

    <h2 class="section-title">Moko Dictionary (Server-Side)</h2>
    <div class="moko-grid">
      <% @mokos.each do |moko| %>
        <div class="moko-card">
          <div class="moko-name"><%= moko.name %></div>
          <div style="font-size: 0.8rem; color: var(--secondary); margin-bottom: 1rem; font-weight: 600;">
            Requires Level <%= moko.required_level %>+ (Phase <%= moko.phase %>)
          </div>
          <div class="moko-desc"><%= moko.description %></div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Real-Time Reactivity via ActionCable -->
  <script src="https://cdn.jsdelivr.net/npm/@rails/actioncable@7.1.3/app/assets/javascripts/actioncable.js"></script>
  <script>
    // Create WebSocket connection to ActionCable
    const consumer = ActionCable.createConsumer('ws://' + window.location.host + '/cable');
    
    consumer.subscriptions.create("LiveStatsChannel", {
      received(data) {
        if (data.event === "sync_completed") {
          console.log("Live Update Received:", data);
          const shortId = data.device.substring(0, 8);
          
          // Show a beautiful live notification toast
          const toast = document.createElement('div');
          toast.style.position = 'fixed';
          toast.style.bottom = '20px';
          toast.style.right = '20px';
          toast.style.background = 'var(--primary)';
          toast.style.color = 'white';
          toast.style.padding = '1rem 1.5rem';
          toast.style.borderRadius = '0.5rem';
          toast.style.boxShadow = '0 10px 15px -3px rgba(0,0,0,0.3)';
          toast.style.zIndex = '9999';
          toast.style.fontWeight = 'bold';
          toast.style.transition = 'opacity 0.5s ease';
          toast.innerHTML = `🔥 Live Activity: User ${shortId}... just synced!`;
          
          document.body.appendChild(toast);
          
          // Auto-dimiss
          setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
          }, 4000);
        } else if (data.type === "moko_party") {
          console.log("🎉 Moko Party Event!", data);
          
          // Create a party announcement
          const party = document.createElement('div');
          party.style.position = 'fixed';
          party.style.top = '50%';
          party.style.left = '50%';
          party.style.transform = 'translate(-50%, -50%)';
          party.style.background = 'linear-gradient(135deg, #c084fc, #38bdf8)';
          party.style.color = 'white';
          party.style.padding = '2rem 3rem';
          party.style.borderRadius = '2rem';
          party.style.boxShadow = '0 20px 25px -5px rgba(0,0,0,0.5)';
          party.style.zIndex = '10000';
          party.style.textAlign = 'center';
          party.style.animation = 'popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
          party.innerHTML = `
            <div style="font-size: 3rem; margin-bottom: 1rem;">🐾🎉🐾</div>
            <div style="font-size: 1.5rem; font-weight: bold;">Moko Party Started!</div>
            <div style="margin-top: 0.5rem;">${data.message}</div>
          `;
          
          document.body.appendChild(party);
          
          // Confetti effect simulation (simple CSS)
          for(let i=0; i<30; i++) {
            const p = document.createElement('div');
            p.style.position = 'fixed';
            p.style.top = '-10px';
            p.style.left = Math.random() * 100 + 'vw';
            p.style.width = '10px';
            p.style.height = '10px';
            p.style.background = ['#38bdf8', '#c084fc', '#fbbf24', '#f87171'][Math.floor(Math.random()*4)];
            p.style.borderRadius = '50%';
            p.style.zIndex = '10001';
            p.style.animation = `fall ${1 + Math.random() * 2}s linear forwards`;
            document.body.appendChild(p);
            setTimeout(() => p.remove(), 3000);
          }
          
          setTimeout(() => {
            party.style.opacity = '0';
            setTimeout(() => party.remove(), 500);
          }, 6000);
        } else if (data.type === "moko_gift") {
          console.log("🎁 Moko Gift Event!", data);
          const toast = document.createElement('div');
          toast.style.position = 'fixed';
          toast.style.bottom = '80px';
          toast.style.right = '20px';
          toast.style.background = '#fbbf24';
          toast.style.color = 'black';
          toast.style.padding = '0.75rem 1rem';
          toast.style.borderRadius = '0.5rem';
          toast.style.boxShadow = '0 10px 15px -3px rgba(0,0,0,0.3)';
          toast.style.zIndex = '9999';
          toast.style.fontWeight = 'bold';
          toast.style.animation = 'popIn 0.3s ease-out';
          toast.innerHTML = `🎁 ${data.message}`;
          document.body.appendChild(toast);
          setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
          }, 5000);
        } else if (data.type === "world_weather_change") {
          console.log("🌍 World Weather Changed!", data.status);
          const weatherEl = document.getElementById('world-weather');
          const eventEl = document.getElementById('world-event-name');
          const banner = document.getElementById('world-banner');
          
          if (weatherEl) weatherEl.innerText = data.status.weather.toUpperCase();
          if (eventEl) eventEl.innerText = data.status.event_name;
          
          // Flash effect
          banner.style.animation = 'pulse 1s ease-in-out';
          setTimeout(() => banner.style.animation = '', 1000);
        }
      }
    });

    // Phase 36: Raid Channel Subscription
    consumer.subscriptions.create("RaidChannel", {
      received(data) {
        console.log("Raid Event Received:", data);
        
        if (data.type === "damage_dealt") {
          const hpBar = document.getElementById('raid-hp-bar');
          const hpText = document.getElementById('raid-hp-text');
          const logs = document.getElementById('raid-logs');
          const container = document.getElementById('raid-boss-container');

          if (hpBar) hpBar.style.width = data.health_percentage + '%';
          if (hpText) hpText.innerText = `${data.current_hp.toLocaleString()} / ${data.max_hp.toLocaleString()} HP`;

          // Add log entry
          if (logs) {
            const entry = document.createElement('div');
            entry.className = 'raid-log-entry';
            entry.style.animation = 'fadeInLeft 0.3s ease-out';
            entry.innerHTML = `<span style="color:white; font-weight:bold;">${data.attacker}</span> が強烈な一撃！ <span style="color:yellow;">-${data.damage} DMG</span>`;
            logs.prepend(entry);
            if (logs.children.length > 3) logs.lastElementChild.remove();
          }

          // Shake effect
          if (container) {
            container.style.animation = 'shake 0.5s cubic-bezier(.36,.07,.19,.97) both';
            setTimeout(() => container.style.animation = '', 500);
          }
        } else if (data.type === "boss_spawned") {
          window.location.reload(); // Quickest way to show the new UI
        } else if (data.type === "boss_defeated") {
          alert("🎉 " + data.message);
          window.location.reload();
        }
      }
    });

    // Add CSS animations
    const style = document.createElement('style');
    style.textContent = `
      @keyframes popIn {
        0% { transform: translate(-50%, -50%) scale(0.5); opacity: 0; }
        100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
      }
      @keyframes fall {
        to { transform: translateY(110vh) rotate(360deg); }
      }
      @keyframes shake {
        10%, 90% { transform: translate3d(-1px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
      }
      @keyframes fadeInLeft {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
      }
    `;
    document.head.appendChild(style);
  </script>
</body>
</html>
